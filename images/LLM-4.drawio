        <mxCell id="AtRTMDIK9vMjEBBKfE-1-49" value="2) 通过 softmax 函数获得每个输入标记的 7 维概率行向量。" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;fontFamily=Maple Mono NF CN;" vertex="1" parent="1">
